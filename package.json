{
  "name": "trello-mcp",
  "version": "1.0.0",
  "description": "Trello integration for any MCP-compatible client via Model Context Protocol (MCP)",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "rebuild": "npm run clean && npm run build",
    "type-check": "tsc --noEmit",
    "start": "node dist/index.js",
    "start:http": "node dist/http-server.js",
    "dev:http": "npm run build && npm run start:http",
    "prepare": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "trello",
    "claude",
    "gemini",
    "ai-assistant",
    "api",
    "integration",
    "productivity",
    "project-management"
  ],
  "author": "Trello MCP Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/trello-desktop-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/yourusername/trello-desktop-mcp/issues"
  },
  "homepage": "https://github.com/yourusername/trello-desktop-mcp#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "better-sqlite3": "^12.9.0",
    "express": "^5.0.0",
    "express-rate-limit": "^8.3.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.3",
    "@types/node": "^22.10.3",
    "typescript": "^5.7.3"
  },
  "files": [
    "dist/**/*",
    "src/**/*",
    "README.md",
    "LICENSE",
    "package.json",
    "tsconfig.json"
  ]
}
