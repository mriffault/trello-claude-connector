# ==========================================================================
# Trello MCP — environment template
# --------------------------------------------------------------------------
# Two deployment profiles are documented below:
#   - LOCAL DEV      (stdio or HTTP on 127.0.0.1, no auth)
#   - DOCKER / VPS   (HTTP behind Traefik, OAuth 2.1 via Google)
# Copy to `.env` and edit. Never commit `.env`.
# ==========================================================================

# ----- Trello credentials (required in both profiles) ---------------------
# https://trello.com/app-key  and  https://trello.com/1/authorize?...
TRELLO_API_KEY=
TRELLO_TOKEN=

# --------------------------------------------------------------------------
# Profile A — LOCAL DEV (stdio mode works as-is; HTTP mode uses PORT/HOST below)
# --------------------------------------------------------------------------
PORT=3000
HOST=127.0.0.1

# --------------------------------------------------------------------------
# Profile B — DOCKER / VPS with Traefik + Google OAuth
# --------------------------------------------------------------------------
# Uncomment and set every variable in this section when deploying to the VPS.

# Public hostname Traefik routes to this container. Used by docker-compose.yml
# in the Traefik router rule (Host(`...`)).
# PUBLIC_HOSTNAME=mcp.example.com

# Full public URL (scheme + host, no trailing slash). Used inside the app to
# build OAuth metadata documents, redirect URIs, and the Bearer auth challenge.
# PUBLIC_BASE_URL=https://mcp.example.com

# Comma-separated hostnames (NOT hosts with ports) the server accepts in the
# Host header. The MCP SDK middleware extracts the hostname via URL parsing and
# compares it port-agnostically, so do not include ports here. Required when
# HOST is 0.0.0.0 (Docker). Must include 127.0.0.1 so the container healthcheck
# passes the DNS-rebinding-protection middleware.
# ALLOWED_HOSTS=mcp.example.com,127.0.0.1

# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
# (type "Web application"). Authorized redirect URI must match exactly:
#   ${PUBLIC_BASE_URL}/oauth/google/callback
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# The ONE email address allowed to sign in (mono-user setup).
# ALLOWED_GOOGLE_EMAIL=you@example.com

# Path to the SQLite database for OAuth state (clients, tokens).
# In Docker, this path lives on the `trello-mcp-data` volume.
# AUTH_DB_PATH=/app/data/auth.db

# Logging: debug | info | warn | error. One JSON line per entry on stderr.
# LOG_LEVEL=info

# Trust-proxy setting for Express. Required behind Traefik so express-rate-limit
# and access logs see the real client IP (via X-Forwarded-For). "1" means "trust
# one hop" which matches a single Traefik in front of the container.
# TRUST_PROXY=1
